{
  "displayName": "Ondus",
  "name": "homebridge-grohe-sense",
  "version": "2.0.0",
  "description": "Homebridge plugin for Grohe Sense Guard, Sense Plus, and Sense water control system.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/faune/homebridge-grohe-sense.git"
  },
  "bugs": {
